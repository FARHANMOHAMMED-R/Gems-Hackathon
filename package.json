{
  "name": "gems-assist-backend",
  "version": "1.0.0",
  "description": "Backend for the Gems Assist education platform: AI grading, content differentiation, smart substitution, lab booking, parent mailer and token economy.",
  "license": "MIT",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "prisma generate && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "build:all": "npm run build && npm run build --prefix frontend",
    "start:site": "SERVE_FRONTEND=true PORT=5173 HOST=0.0.0.0 node dist/src/index.js",
    "site": "npm run build:all && npm run start:site",
    "share": "node scripts/site-share.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "nodemailer": "^9.0.1",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "tesseract.js": "^5.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "homepage": "https://gems-class-flow.base44.app"
}
