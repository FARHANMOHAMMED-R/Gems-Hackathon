# Gems Assist frontend — copy to `.env` for local overrides (optional).
#
# Base URL for the Express API. Leave empty when using the Vite dev proxy
# (default): requests go to /api and /health on the same origin and Vite
# forwards them to http://localhost:4000.
#
# For production static hosting (Vercel, Netlify, S3, etc.), set this to your
# deployed backend origin — no trailing slash.
#
# Examples:
#   VITE_API_BASE=http://localhost:4000
#   VITE_API_BASE=https://api.your-domain.com
VITE_API_BASE=

# Optional — auto-configures Gemini in all browser AI tools (gitignored via .env.local).
# Get a free key at https://aistudio.google.com/apikey
# VITE_GEMINI_API_KEY=AIzaSy...
