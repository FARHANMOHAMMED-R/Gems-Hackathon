# ---- Server ----
PORT=4000
# Bind to all interfaces so other devices on your Wi‑Fi can reach the API (optional).
HOST=0.0.0.0

# ---- Database (SQLite by default for zero-config local dev) ----
# Swap for a PostgreSQL/MySQL URL in production and update prisma/schema.prisma datasource.
DATABASE_URL="file:./dev.db"

# ---- LLM provider (OpenAI-compatible) ----
# Works with OpenAI, Azure OpenAI, or any OpenAI-compatible gateway.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# Text + reasoning model used for grading, differentiation and mail drafting.
LLM_TEXT_MODEL="gpt-4o"
# Multimodal model used to OCR/transcribe scanned answer sheets & notebooks.
LLM_VISION_MODEL="gpt-4o"

# ---- Google Gemini (free tier OCR alternative) ----
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# GEMINI_VISION_MODEL="gemini-2.0-flash"

# ---- Anthropic Claude ----
# https://console.anthropic.com/
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-sonnet-4-20250514"

# Default when multiple keys are set: openai | gemini | claude
LLM_DEFAULT_PROVIDER="openai"

# ---- PDF Guru / GuruPDF image-to-text OCR ----
# Powers notebook & exam scan OCR (https://pdfguru.com/app/image-to-text).
# Get a free API key: https://gurupdf.com/api → profile → generate key.
GURUPDF_API_KEY=""
# GURUPDF_BASE_URL="https://gurupdf.com"

# ---- Parent Mailer (Resend or SMTP) ----
# Resend (recommended): https://resend.com — free tier for dev/testing.
RESEND_API_KEY=""
# From address — use a verified domain in production (Resend onboarding@resend.dev works for testing).
MAIL_FROM="Gems Assist <onboarding@resend.dev>"

# Or SMTP (Gmail, Outlook, school mail server):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="you@gmail.com"
# SMTP_PASS="app-password"
