// Gems Assist — data model
// Default datasource is SQLite for zero-config local dev. For production, switch
// `provider` to "postgresql" / "mysql" and point DATABASE_URL at your cluster.
// This SQLite connector supports neither native enums nor a `Json` column, so
// JSON/array-shaped fields are stored as serialized `String` (JSON text) and
// (de)serialized via src/lib/json.ts on the application layer. On Postgres/MySQL
// you can switch these back to `Json` and the string columns to enums.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A learner. `adaptivePreferenceProfile` holds the differentiation profile
/// (e.g. { "track": "Neurodivergent", "subtype": "ADHD", "pace": "micro" }).
model StudentProfile {
  id                        String          @id @default(cuid())
  name                      String
  grade                     String
  section                   String
  rollNumber                String          @default("") @map("roll_number")
  schoolId                  String          @default("") @map("school_id")
  /// Class key matching TeacherProfile.classManaged, e.g. "11-A"
  classManaged              String          @default("") @map("class_managed")
  /// Parent/guardian email for Parent Mailer delivery
  parentEmail               String          @default("") @map("parent_email")
  totalTokens               Int             @default(0) @map("total_tokens")
  /// JSON string, e.g. {"track":"Neurodivergent","subtype":"ADHD","pace":"micro"}
  adaptivePreferenceProfile String?         @map("adaptive_preference_profile")
  gradingRecords            GradingRecord[]
  performanceMarks          PerformanceMark[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([classManaged, rollNumber], name: "class_roll")
  @@index([grade, section])
  @@index([classManaged])
  @@index([totalTokens])
  @@map("student_profiles")
}

/// An AI-graded artifact (exam paper or notebook).
/// `scores` is a JSON breakdown, e.g. { "Handwriting": 4, "Creativity": 3, "Content": 5 }
/// or per-question marks for exams.
model GradingRecord {
  id             String   @id @default(cuid())
  studentId      String   @map("student_id")
  /// Allowed values: "Exam" | "Notebook" (enforced at the application layer;
  /// SQLite has no native enum — switch to a Prisma enum on Postgres/MySQL).
  type           String
  rawScannedText String   @map("raw_scanned_text")
  /// JSON string score breakdown, e.g. {"Handwriting":4,"Creativity":3,"Content":5}
  scores         String
  aiFeedbackText String   @map("ai_feedback_text")
  dateTimestamp  DateTime @default(now()) @map("date_timestamp")

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, dateTimestamp])
  @@map("grading_records")
}

/// Term-wise marks per subject for performance tracking (PT1 → Final).
model PerformanceMark {
  id           String   @id @default(cuid())
  studentId    String   @map("student_id")
  classManaged String   @map("class_managed")
  subject      String
  /// Allowed values: "PT1" | "Half Yearly" | "PT2" | "Final"
  examPeriod   String   @map("exam_period")
  marks        Float
  maxMarks     Float    @default(100) @map("max_marks")
  /// e.g. "2025-26" — empty string = current default year bucket
  academicYear String   @default("") @map("academic_year")

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subject, examPeriod, academicYear], name: "student_subject_exam_year")
  @@index([classManaged, subject])
  @@map("performance_marks")
}

/// Recorded classroom lecture with transcript, timeline, and AI summary.
model LectureRecording {
  id              String   @id @default(cuid())
  classManaged    String   @map("class_managed")
  teacherEmail    String   @default("") @map("teacher_email")
  teacherName     String   @default("") @map("teacher_name")
  title           String
  subject         String   @default("")
  durationSeconds Int      @default(0) @map("duration_seconds")
  transcript      String   @default("")
  summary         String   @default("")
  /// JSON string array of key points
  keyPoints       String   @default("[]") @map("key_points")
  /// JSON array of timeline entries
  timeline        String   @default("[]")
  /// JSON array of teacher notes captured during recording
  notes           String   @default("[]")
  /// "ai" | "local"
  analysisMode    String   @default("local") @map("analysis_mode")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([classManaged, createdAt])
  @@map("lecture_recordings")
}

/// A bookable lab room slot. Uniqueness on (room, date, period) is the
/// hard guarantee that powers double-booking prevention.
model LabReservation {
  id                  String  @id @default(cuid())
  roomName            String  @map("room_name")
  periodNumber        Int     @map("period_number")
  date                String // ISO date (YYYY-MM-DD) — date-only granularity
  reservedByTeacherId String? @map("reserved_by_teacher_id")
  /// Allowed values: "Free" | "Occupied" (application-enforced; see note above).
  status              String  @default("Free")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([roomName, date, periodNumber], name: "room_date_period")
  @@index([date])
  @@map("lab_reservations")
}

/// Signed-in teacher profile (upserted on each sign-in by email).
model TeacherProfile {
  id            String @id @default(cuid())
  name          String
  classManaged  String @map("class_managed")
  email         String @unique
  lastSeenAt    DateTime? @map("last_seen_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("teacher_profiles")
}

/// Staff-lounge message between signed-in teachers.
model TeacherChatMessage {
  id           String   @id @default(cuid())
  teacherId    String   @map("teacher_id")
  teacherName  String   @map("teacher_name")
  classManaged String   @map("class_managed")
  teacherEmail String   @map("teacher_email")
  body         String
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("teacher_chat_messages")
}

/// Broadcast notice from admin to all teachers.
model AdminNotification {
  id        String   @id @default(cuid())
  title     String
  body      String
  /// Allowed values: "info" | "warning" | "urgent" (application-enforced).
  priority  String   @default("info")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("admin_notifications")
}

/// A teacher's per-period availability for the current day.
/// `currentPeriodFreeStatus` is a 7-element boolean array (periods 1..7),
/// stored as Json. `department` enables department-matched substitution.
model TeacherAvailability {
  id                      String  @id @default(cuid())
  teacherName             String  @map("teacher_name")
  department              String  @default("General")
  /// JSON string: 7-element boolean array for periods 1..7, e.g. "[true,false,...]"
  currentPeriodFreeStatus String  @map("current_period_free_status")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([department])
  @@map("teacher_availability")
}
